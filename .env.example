# ===========================================
# SymbolERP 環境變數配置範本
# ===========================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# ----- PostgreSQL 資料庫設定 -----
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=symbolerp
DB_HOST=localhost
DB_PORT=5432

# ----- Backend (NestJS) 設定 -----
BACKEND_PORT=3001
NODE_ENV=development

# ----- Admin Panel (Next.js) 設定 -----
ADMIN_PANEL_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----- Docker 容器設定 -----
CONTAINER_PREFIX=symbolerp
