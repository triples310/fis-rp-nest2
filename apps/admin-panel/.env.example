# ===========================================
# Admin Panel (Next.js) 環境變數範本
# ===========================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# ----- API 端點設定 -----
# NEXT_PUBLIC_ 前綴的變數會暴露到瀏覽器端
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----- 其他前端設定 (未來使用) -----
# NEXT_PUBLIC_APP_NAME=SymbolERP
# NEXT_PUBLIC_APP_VERSION=1.0.0
