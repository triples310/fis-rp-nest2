# ===========================================
# Backend (NestJS) 環境變數範本
# ===========================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# ----- 資料庫連線 -----
# 格式: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/symbolerp?schema=public"

# ----- 應用程式設定 -----
NODE_ENV=development
PORT=3001

# ----- JWT 設定 (未來使用) -----
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRES_IN=7d

# ----- CORS 設定 (未來使用) -----
# CORS_ORIGIN=http://localhost:3000
